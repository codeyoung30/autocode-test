/* 容器 */
.container {
  padding: 20rpx;
  padding-bottom: 60rpx;
}

/* 头部 */
.header {
  text-align: center;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}
.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
  margin-bottom: 10rpx;
}
.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

/* 导航标签 */
.nav-tabs {
  margin-bottom: 20rpx;
  white-space: nowrap;
}
.nav-tab-wrapper {
  display: flex;
  gap: 12rpx;
  padding: 4rpx;
}
.nav-tab {
  display: inline-block;
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.15);
  color: white;
  font-size: 24rpx;
  transition: all 0.3s;
}
.nav-tab.active {
  background: white;
  color: var(--accent);
  border-color: white;
  font-weight: 600;
}

/* 卡片 */
.card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}
.card-header {
  margin-bottom: 10rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--dark);
}
.card-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 20rpx;
  line-height: 1.5;
}

/* 分区标签 */
.section-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--accent);
  margin: 30rpx 0 20rpx 0;
  text-transform: uppercase;
}

/* 流程图 */
.process-flow {
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
  padding-left: 60rpx;
  margin: 20rpx 0;
}
.process-flow::before {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 4rpx;
  background: linear-gradient(180deg, var(--fat-color), var(--muscle-color));
}
.flow-step {
  position: relative;
  padding: 16rpx 0 24rpx 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}
.flow-step::before {
  content: '';
  position: absolute;
  left: -46rpx;
  top: 24rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: white;
  border: 6rpx solid var(--accent);
  z-index: 1;
}
.flow-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.flow-content {
  flex: 1;
}
.flow-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--dark);
  margin-bottom: 4rpx;
}
.flow-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  line-height: 1.4;
}

/* 条形图 */
.bar-chart {
  margin: 20rpx 0;
}
.bar-item {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border);
}
.bar-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}
.bar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.bar-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--dark);
}
.bar-value {
  font-size: 22rpx;
  color: var(--text-light);
}
.bar-track {
  height: 36rpx;
  background: #f0f0f0;
  border-radius: 18rpx;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 16rpx;
  color: white;
  font-size: 22rpx;
  font-weight: 600;
}

/* 多值条形图 */
.multi-bar-chart {
  margin: 20rpx 0;
  padding: 20rpx;
  background: var(--light-bg);
  border-radius: 16rpx;
}
.multi-bar-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 16rpx;
}
.multi-bar-item:last-child {
  margin-bottom: 0;
}
.multi-bar-label {
  width: 140rpx;
  font-size: 22rpx;
  color: var(--text-light);
  flex-shrink: 0;
}
.multi-bar-track {
  flex: 1;
  height: 32rpx;
  background: #e0e0e0;
  border-radius: 16rpx;
  overflow: hidden;
}
.multi-bar-fill {
  height: 100%;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12rpx;
  color: white;
  font-size: 20rpx;
  font-weight: 600;
}
.chart-note {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  text-align: center;
  margin-top: 16rpx;
}

/* 表格 */
.table-scroll {
  margin: 0 -30rpx;
  padding: 0 30rpx;
}
.table {
  min-width: 700rpx;
  border-collapse: collapse;
}
.table-header, .table-row {
  display: flex;
  border-bottom: 2rpx solid var(--border);
}
.table-header {
  background: var(--light-bg);
  font-weight: 700;
}
.table-cell {
  flex: 1;
  padding: 20rpx 16rpx;
  font-size: 22rpx;
  min-width: 160rpx;
}
.table-cell.fat {
  color: var(--fat-color);
  font-weight: 600;
}
.table-cell.muscle {
  color: #00897B;
  font-weight: 600;
}

/* 周计划表格 */
.plan-scroll {
  margin: 0 -30rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}
.plan-table {
  min-width: 650rpx;
}
.plan-header, .plan-row {
  display: flex;
  border-bottom: 2rpx solid var(--border);
}
.plan-header {
  background: var(--light-bg);
  font-weight: 700;
}
.plan-cell {
  flex: 1;
  padding: 16rpx;
  font-size: 22rpx;
}
.plan-cell:first-child {
  min-width: 100rpx;
  max-width: 100rpx;
}

/* KPI卡片 */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 20rpx 0;
}
.kpi-card {
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}
.kpi-card.fat-theme { 
  background: linear-gradient(135deg, #FF6B6B20, #FF6B6B40); 
  border: 2rpx solid #FF6B6B60; 
}
.kpi-card.muscle-theme { 
  background: linear-gradient(135deg, #4ECDC420, #4ECDC440); 
  border: 2rpx solid #4ECDC460; 
}
.kpi-card.protein-theme { 
  background: linear-gradient(135deg, #45B7D120, #45B7D140); 
  border: 2rpx solid #45B7D160; 
}
.kpi-card.carb-theme { 
  background: linear-gradient(135deg, #FFA07A20, #FFA07A40); 
  border: 2rpx solid #FFA07A60; 
}
.kpi-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--dark);
  line-height: 1.2;
}
.kpi-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 8rpx;
  line-height: 1.3;
}
.kpi-sublabel {
  display: block;
  font-size: 20rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

/* 提示框 */
.insight-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 20rpx 0;
}
.insight-box {
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}
.insight-box.warning { 
  background: #FFF3E0; 
  border-left: 6rpx solid #FF9800; 
}
.insight-box.info { 
  background: #E3F2FD; 
  border-left: 6rpx solid #2196F3; 
}
.insight-box.success { 
  background: #E8F5E9; 
  border-left: 6rpx solid #4CAF50; 
}
.insight-box.danger { 
  background: #FFEBEE; 
  border-left: 6rpx solid #F44336; 
}
.insight-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.insight-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text);
}
.bold {
  font-weight: 600;
  color: var(--dark);
}

/* 堆叠条形图 */
.macro-bar {
  margin: 16rpx 0 24rpx 0;
}
.macro-header {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}
.macro-ratio {
  color: var(--text-light);
  font-size: 22rpx;
}
.stacked-bar {
  height: 48rpx;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
}
.stack-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: white;
}

/* 训练对比 */
.training-compare {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid var(--border);
}
.training-compare:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}
.training-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--dark);
  margin-bottom: 16rpx;
}
.compare-bars {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.compare-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.compare-label {
  width: 100rpx;
  font-size: 22rpx;
  color: var(--text-light);
}
.compare-track {
  flex: 1;
  height: 32rpx;
  background: #e0e0e0;
  border-radius: 16rpx;
  overflow: hidden;
}
.compare-fill {
  height: 100%;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12rpx;
  color: white;
  font-size: 20rpx;
  font-weight: 600;
}

/* 身体成分对比 */
.body-comp-item {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: var(--light-bg);
  border-radius: 16rpx;
}
.comp-header {
  margin-bottom: 16rpx;
}
.comp-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--dark);
}
.comp-bars {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.comp-bar-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.comp-label {
  width: 80rpx;
  font-size: 22rpx;
  color: var(--text-light);
  text-align: right;
}
.comp-track {
  flex: 1;
  height: 36rpx;
  background: #e0e0e0;
  border-radius: 18rpx;
  overflow: hidden;
}
.comp-fill {
  height: 100%;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12rpx;
  color: white;
  font-size: 22rpx;
  font-weight: 600;
}
.comp-fill.fat {
  background: var(--fat-color);
}
.comp-fill.muscle {
  background: var(--muscle-color);
}

/* 气泡图 */
.bubble-chart {
  position: relative;
  height: 280rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin: 20rpx 0;
}
.bubble {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}
.bubble-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
}
.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

/* 效率对比 */
.efficiency-compare {
  margin-bottom: 30rpx;
  padding: 24rpx;
  background: var(--light-bg);
  border-radius: 16rpx;
}
.efficiency-compare.star {
  background: linear-gradient(135deg, #E8F5E920, #4ECDC420);
  border: 2rpx solid #4ECDC460;
}
.eff-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--dark);
  margin-bottom: 16rpx;
}
.eff-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 16rpx;
}
.eff-item:last-child {
  margin-bottom: 0;
}
.eff-label {
  width: 140rpx;
  font-size: 22rpx;
  color: var(--text-light);
}
.eff-track {
  flex: 1;
  height: 36rpx;
  background: #e0e0e0;
  border-radius: 18rpx;
  overflow: hidden;
}
.eff-fill {
  height: 100%;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12rpx;
  color: white;
  font-size: 22rpx;
  font-weight: 600;
}

/* 决策卡片 */
.decision-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid;
}
.decision-header {
  margin-bottom: 12rpx;
}
.decision-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}
.decision-subtitle {
  display: block;
  font-size: 22rpx;
  color: var(--text-light);
}
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.tag.red { background: #FFEBEE; color: #C62828; }
.tag.green { background: #E8F5E9; color: #1B5E20; }
.tag.blue { background: #E3F2FD; color: #0D47A1; }
.tag.orange { background: #FFF3E0; color: #E65100; }
.tag.purple { background: #F3E5F5; color: #4A148C; }
.decision-content {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--text);
  white-space: pre-line;
}

/* 结论列表 */
.conclusion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.conclusion-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  align-items: flex-start;
}
.conclusion-item.info { background: #E3F2FD; border-left: 6rpx solid #2196F3; }
.conclusion-item.success { background: #E8F5E9; border-left: 6rpx solid #4CAF50; }
.conclusion-item.warning { background: #FFF3E0; border-left: 6rpx solid #FF9800; }
.conclusion-item.danger { background: #FFEBEE; border-left: 6rpx solid #F44336; }
.conclusion-icon {
  font-size: 36rpx;
}
.conclusion-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 20rpx;
  margin-top: 20rpx;
}
.footer text {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1.6;
}
